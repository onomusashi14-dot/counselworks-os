# Default: API calls are proxied through the Next.js rewrite at /api/*.
# Override only if you want the browser to call the backend directly
# (which requires your origin to be on the backend's CORS allow-list).
# NEXT_PUBLIC_API_URL=https://counselworks-api-production.up.railway.app

# Optional — point the /api/* rewrite at a different upstream (e.g. a
# locally running API at http://localhost:4000).
# API_PROXY_TARGET=http://localhost:4000
